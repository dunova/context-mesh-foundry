<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.contextgo.auto-update</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>__SCRIPTS_DIR__/auto_update.sh</string>
	</array>
	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>__HOME__</string>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
		<key>CONTEXTGO_REPO_DIR</key>
		<string>__HOME__/ContextGO</string>
		<key>CONTEXTGO_LOG_DIR</key>
		<string>__HOME__/.contextgo/logs</string>
	</dict>
	<key>StartInterval</key>
	<integer>900</integer>
	<key>StandardOutPath</key>
	<string>__LOG_DIR__/auto_update_launchd.log</string>
	<key>StandardErrorPath</key>
	<string>__LOG_DIR__/auto_update_launchd.err</string>
</dict>
</plist>
