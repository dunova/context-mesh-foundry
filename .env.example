# ContextGO - Environment Variables Reference
# Copy this file to .env and adjust values for your local setup.
# Lines prefixed with '#' are comments. Uncomment and set values as needed.
#
# SECURITY NOTE: Never commit a populated .env file to version control.
# The .env file is listed in .gitignore. This .env.example file is safe
# to commit as it contains no real secrets.

# ---------------------------------------------------------------------------
# Optional: External API compatibility
# ---------------------------------------------------------------------------

# Google Gemini API key. Only required if using the Gemini-backed autoresearch
# or evaluation features. Leave blank (default) for local-only operation.
GEMINI_API_KEY=

# ---------------------------------------------------------------------------
# Optional: Remote sync (disabled by default; must be HTTPS for non-localhost)
# ---------------------------------------------------------------------------

# Base URL of a remote ContextGO sync server. Must use https:// unless the
# host is 127.0.0.1, localhost, or ::1. The daemon enforces this at startup.
# CONTEXTGO_REMOTE_URL=http://127.0.0.1:8090/api/v1

# Enable pushing new history entries to the remote sync server over HTTP.
# 0 = disabled (default). Requires CONTEXTGO_REMOTE_URL to be set.
# CONTEXTGO_ENABLE_REMOTE_MEMORY_HTTP=0

# Timeout (seconds) for outbound HTTP export requests to the remote server.
# CONTEXTGO_EXPORT_HTTP_TIMEOUT_SEC=30

# Timeout (seconds) for retrying pending outbound HTTP requests.
# CONTEXTGO_PENDING_HTTP_TIMEOUT_SEC=15

# Seconds between retries of failed pending HTTP uploads.
# CONTEXTGO_PENDING_RETRY_INTERVAL_SEC=60

# ---------------------------------------------------------------------------
# Optional: Storage paths
# ---------------------------------------------------------------------------

# Root directory for all ContextGO data (index DBs, logs, memory files).
# Defaults to ~/.contextgo. Must be owned by and writable by the current user.
# CONTEXTGO_STORAGE_ROOT=$HOME/.contextgo

# Override path for the memory observations SQLite database.
# Defaults to $CONTEXTGO_STORAGE_ROOT/index/memory_index.db
# MEMORY_INDEX_DB_PATH=$CONTEXTGO_STORAGE_ROOT/index/memory_index.db

# Override path for the session index SQLite database.
# Defaults to $CONTEXTGO_STORAGE_ROOT/index/session_index.db
# CONTEXTGO_SESSION_INDEX_DB_PATH=$CONTEXTGO_STORAGE_ROOT/index/session_index.db

# ---------------------------------------------------------------------------
# Optional: Memory Viewer server
# ---------------------------------------------------------------------------

# Host address for the local memory viewer HTTP server.
# Defaults to 127.0.0.1 (loopback only). Do NOT bind to 0.0.0.0 without
# also setting CONTEXTGO_VIEWER_TOKEN to a strong random secret.
# CONTEXTGO_VIEWER_HOST=127.0.0.1

# TCP port for the memory viewer server.
# CONTEXTGO_VIEWER_PORT=37677

# Bearer token required on the X-Context-Token header for all /api/ requests.
# Required when CONTEXTGO_VIEWER_HOST is not a loopback address.
# Use a random high-entropy value, e.g.: openssl rand -hex 32
# CONTEXTGO_VIEWER_TOKEN=

# Maximum request body size (bytes) accepted by the viewer POST endpoints.
# CONTEXTGO_VIEWER_MAX_POST_BYTES=1048576

# Maximum number of IDs accepted in a single batch observations request.
# CONTEXTGO_VIEWER_MAX_BATCH_IDS=500

# ---------------------------------------------------------------------------
# Optional: Daemon source monitors (each defaults to enabled unless noted)
# ---------------------------------------------------------------------------

# Monitor shell history files (~/.zsh_history, ~/.bash_history).
# CONTEXTGO_ENABLE_SHELL_MONITOR=1 (default: enabled)
# CONTEXTGO_ENABLE_SHELL_MONITOR=0

# Monitor ~/.claude/history.jsonl for Claude Code prompt history.
# CONTEXTGO_ENABLE_CLAUDE_HISTORY_MONITOR=1

# Monitor ~/.codex/history.jsonl for Codex prompt history.
# CONTEXTGO_ENABLE_CODEX_HISTORY_MONITOR=1

# Monitor OpenCode prompt history (default: disabled).
# CONTEXTGO_ENABLE_OPENCODE_MONITOR=0

# Monitor Kilo prompt history (default: disabled).
# CONTEXTGO_ENABLE_KILO_MONITOR=0

# Enable remote sync to CONTEXTGO_REMOTE_URL (default: disabled).
# CONTEXTGO_ENABLE_REMOTE_SYNC=0

# Monitor ~/.codex/sessions for full Codex session JSONL files.
# CONTEXTGO_ENABLE_CODEX_SESSION_MONITOR=1

# Monitor ~/.claude/transcripts for Claude transcript files.
# CONTEXTGO_ENABLE_CLAUDE_TRANSCRIPTS_MONITOR=1

# Monitor ~/.gemini/antigravity/brain for Antigravity session docs.
# CONTEXTGO_ENABLE_ANTIGRAVITY_MONITOR=1

# ---------------------------------------------------------------------------
# Optional: Daemon timing and resource tuning
# ---------------------------------------------------------------------------

# Normal poll interval in seconds between daemon work cycles.
# CONTEXTGO_POLL_INTERVAL_SEC=180

# Fast poll interval in seconds (used when recent activity is detected).
# CONTEXTGO_FAST_POLL_INTERVAL_SEC=20

# Maximum idle sleep cap in seconds.
# CONTEXTGO_IDLE_SLEEP_CAP_SEC=600

# Heartbeat log interval in seconds.
# CONTEXTGO_HEARTBEAT_INTERVAL_SEC=600

# Seconds of inactivity before entering idle mode.
# CONTEXTGO_IDLE_TIMEOUT_SEC=300

# Minimum seconds between successive index sync operations.
# CONTEXTGO_INDEX_SYNC_MIN_INTERVAL_SEC=20

# Jitter added to loop sleep to spread load (seconds, float).
# CONTEXTGO_LOOP_JITTER_SEC=0.7

# Maximum backoff between error retries in seconds.
# CONTEXTGO_ERROR_BACKOFF_MAX_SEC=30

# Maximum seconds per daemon work cycle budget.
# CONTEXTGO_CYCLE_BUDGET_SEC=8

# Poll interval during night hours (see NIGHT_POLL_START/END_HOUR).
# CONTEXTGO_NIGHT_POLL_INTERVAL_SEC=900

# Maximum number of in-memory tracked sessions.
# CONTEXTGO_MAX_TRACKED_SESSIONS=240

# Maximum number of file byte-offset cursors tracked in memory.
# CONTEXTGO_MAX_FILE_CURSORS=800

# Time-to-live for inactive sessions in memory (seconds).
# CONTEXTGO_SESSION_TTL_SEC=7200

# Maximum messages extracted per session before truncation.
# CONTEXTGO_MAX_MESSAGES_PER_SESSION=500

# How often to rescan Codex session files (seconds).
# CONTEXTGO_CODEX_SESSION_SCAN_INTERVAL_SEC=300

# How often to rescan Claude transcript files (seconds).
# CONTEXTGO_CLAUDE_TRANSCRIPT_SCAN_INTERVAL_SEC=300

# How often to rescan Antigravity brain dirs (seconds).
# CONTEXTGO_ANTIGRAVITY_SCAN_INTERVAL_SEC=300

# Max Codex session files processed per scan pass.
# CONTEXTGO_MAX_CODEX_SESSION_FILES_PER_SCAN=160

# Max Claude transcript files processed per poll pass.
# CONTEXTGO_MAX_CLAUDE_TRANSCRIPT_FILES_PER_POLL=120

# Max Antigravity brain dirs processed per scan pass.
# CONTEXTGO_MAX_ANTIGRAVITY_DIRS_PER_SCAN=80

# Pause Antigravity scanning when the system is busy (1=yes, default).
# CONTEXTGO_SUSPEND_ANTIGRAVITY_WHEN_BUSY=1

# Number of active Antigravity language server processes considered "busy".
# CONTEXTGO_ANTIGRAVITY_BUSY_LS_THRESHOLD=2

# Ingest mode for Antigravity docs: "final_only" or "live".
# CONTEXTGO_ANTIGRAVITY_INGEST_MODE=final_only

# Quiet period (seconds) before an Antigravity dir is considered stable.
# CONTEXTGO_ANTIGRAVITY_QUIET_SEC=240

# Minimum document size (bytes) for Antigravity ingest.
# CONTEXTGO_ANTIGRAVITY_MIN_DOC_BYTES=500

# ---------------------------------------------------------------------------
# Optional: Deployment / install
# ---------------------------------------------------------------------------

# Override the installed ContextGO scripts directory.
# Defaults to ~/.local/share/contextgo
# CONTEXTGO_INSTALL_ROOT=$HOME/.local/share/contextgo

# Patch launchd plist during install (macOS only). 1=yes, 0=no.
# PATCH_LAUNCHD=1

# Reload launchd service after patching (macOS only). 1=yes, 0=no.
# RELOAD_LAUNCHD=1

# ---------------------------------------------------------------------------
# Optional: Native backend
# ---------------------------------------------------------------------------

# Directory for Rust/Go native build artifacts.
# Defaults to /tmp/contextgo_target (volatile; rebuilt as needed).
# For persistent builds, set this to a path in your home directory, e.g.:
# CONTEXTGO_NATIVE_TARGET_DIR=$HOME/.cache/contextgo/target
# CONTEXTGO_NATIVE_TARGET_DIR=/tmp/contextgo_target

# TTL (seconds) for caching the native backend health probe result.
# CONTEXTGO_NATIVE_HEALTH_CACHE_TTL_SEC=30

# ---------------------------------------------------------------------------
# Optional: LiteLLM
# ---------------------------------------------------------------------------

# Use local model cost map instead of fetching from LiteLLM CDN.
# LITELLM_LOCAL_MODEL_COST_MAP=True
