# Context Mesh Foundry 1.0 - Environment Variables
# Copy this file to .env and adjust values for your setup.

# --- Required ---
# Gemini API key used by OpenViking embedding path
GEMINI_API_KEY=

# --- Optional: OpenViking ---
# OPENVIKING_URL=http://<host>:8090/api/v1
# OPENVIKING_DATA_DIR=$HOME/.openviking_data
# OPENVIKING_VENV_DIR=$HOME/.openviking_env
# OPENVIKING_HOST=<host>
# OPENVIKING_PORT=8090
# OPENVIKING_CONFIG_FILE=$OPENVIKING_DATA_DIR/ov.conf
# OPENVIKING_CONFIG_GENERATOR=
# OPENVIKING_SKIP_PIP=1
# OPENVIKING_UPGRADE_PIP=0
# OPENVIKING_FORCE_UPGRADE=0
# OPENVIKING_PORT_WAIT_SEC=20
# OPENVIKING_GENERATOR_TIMEOUT_SEC=20
# OPENVIKING_ALLOW_NAS_GENERATOR=0
# OPENVIKING_ALLOW_EXTERNAL_GENERATOR=0
# OPENVIKING_HTTP_TIMEOUT_SEC=20

# --- Optional: Unified Context Storage ---
# UNIFIED_CONTEXT_STORAGE_ROOT=$HOME/.unified_context_data
# MEMORY_INDEX_DB_PATH=$UNIFIED_CONTEXT_STORAGE_ROOT/index/memory_index.db

# --- Optional: Memory Viewer (P2) ---
# CONTEXT_VIEWER_HOST=127.0.0.1
# CONTEXT_VIEWER_PORT=37677
# CONTEXT_VIEWER_TOKEN=
# CONTEXT_VIEWER_MAX_POST_BYTES=1048576
# CONTEXT_VIEWER_MAX_BATCH_IDS=500

# --- Optional: Daemon tuning ---
# VIKING_ENABLE_SHELL_MONITOR=0
# VIKING_ENABLE_CLAUDE_HISTORY_MONITOR=1
# VIKING_ENABLE_CODEX_HISTORY_MONITOR=1
# VIKING_ENABLE_OPENCODE_MONITOR=0
# VIKING_ENABLE_KILO_MONITOR=0
# VIKING_ENABLE_CODEX_SESSION_MONITOR=1
# VIKING_ENABLE_CLAUDE_TRANSCRIPTS_MONITOR=1
# VIKING_ENABLE_ANTIGRAVITY_MONITOR=1
# VIKING_IDLE_TIMEOUT_SEC=300
# VIKING_POLL_INTERVAL_SEC=180
# VIKING_HEARTBEAT_INTERVAL_SEC=600
# VIKING_FAST_POLL_INTERVAL_SEC=20
# VIKING_IDLE_SLEEP_CAP_SEC=600
# VIKING_NIGHT_POLL_INTERVAL_SEC=900
# VIKING_PENDING_RETRY_INTERVAL_SEC=60
# VIKING_MAX_TRACKED_SESSIONS=240
# VIKING_MAX_FILE_CURSORS=800
# VIKING_SESSION_TTL_SEC=7200
# VIKING_MAX_MESSAGES_PER_SESSION=500
# VIKING_CODEX_SESSION_SCAN_INTERVAL_SEC=300
# VIKING_CLAUDE_TRANSCRIPT_SCAN_INTERVAL_SEC=300
# VIKING_ANTIGRAVITY_SCAN_INTERVAL_SEC=300
# VIKING_MAX_CODEX_SESSION_FILES_PER_SCAN=160
# VIKING_MAX_CLAUDE_TRANSCRIPT_FILES_PER_POLL=120
# VIKING_MAX_ANTIGRAVITY_DIRS_PER_SCAN=80
# VIKING_SUSPEND_ANTIGRAVITY_WHEN_BUSY=1
# VIKING_ANTIGRAVITY_BUSY_LS_THRESHOLD=2
# VIKING_ANTIGRAVITY_INGEST_MODE=final_only
# VIKING_ANTIGRAVITY_QUIET_SEC=240
# VIKING_ANTIGRAVITY_MIN_DOC_BYTES=500
# VIKING_EXPORT_HTTP_TIMEOUT_SEC=30
# VIKING_PENDING_HTTP_TIMEOUT_SEC=15

# --- Optional: MCP tuning ---
# OPENVIKING_ENABLE_SEMANTIC_QUERY=0
# OPENVIKING_MCP_MAX_PROCS=1
# OPENVIKING_MCP_FORCE_TRIM=1
# OPENVIKING_MCP_STALE_SEC=1800

# --- Optional: Deploy ---
# CANON_OV_ROOT=
# GSD_CANON_ROOT=
# CLAUDE_GSD_LINK=$HOME/.claude/get-shit-done
# PATCH_LAUNCHD=1
# RELOAD_LAUNCHD=1

# --- Optional: Legacy compatibility shim ---
# ONECONTEXT_BIN=
# ONECONTEXT_DB_PATH=
# ALLOW_NOOP_MCP=0

# --- Optional: LiteLLM ---
# LITELLM_LOCAL_MODEL_COST_MAP=True
