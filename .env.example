# contextmesh - Environment Variables
# Copy this file to .env and adjust values for your setup.

# --- Required ---
# Optional API keys for legacy remote-sync / future extensions
GEMINI_API_KEY=

# --- Optional: Remote sync ---
# CONTEXT_MESH_REMOTE_URL=http://<host>:8090/api/v1
# CONTEXT_MESH_ENABLE_REMOTE_MEMORY_HTTP=0
# CONTEXT_MESH_EXPORT_HTTP_TIMEOUT_SEC=30
# CONTEXT_MESH_PENDING_HTTP_TIMEOUT_SEC=15
# CONTEXT_MESH_PENDING_RETRY_INTERVAL_SEC=60

# --- Optional: Unified Context Storage ---
# CONTEXT_MESH_STORAGE_ROOT=$HOME/.unified_context_data
# UNIFIED_CONTEXT_STORAGE_ROOT=$HOME/.unified_context_data
# MEMORY_INDEX_DB_PATH=$UNIFIED_CONTEXT_STORAGE_ROOT/index/memory_index.db
# CONTEXT_MESH_SESSION_INDEX_DB_PATH=$CONTEXT_MESH_STORAGE_ROOT/index/session_index.db

# --- Optional: Memory Viewer (P2) ---
# CONTEXT_MESH_VIEWER_HOST=127.0.0.1
# CONTEXT_MESH_VIEWER_PORT=37677
# CONTEXT_MESH_VIEWER_TOKEN=
# CONTEXT_VIEWER_HOST=127.0.0.1
# CONTEXT_VIEWER_PORT=37677
# CONTEXT_VIEWER_TOKEN=
# CONTEXT_VIEWER_MAX_POST_BYTES=1048576
# CONTEXT_VIEWER_MAX_BATCH_IDS=500

# --- Optional: Daemon tuning ---
# CONTEXT_MESH_ENABLE_SHELL_MONITOR=0
# CONTEXT_MESH_ENABLE_CLAUDE_HISTORY_MONITOR=1
# CONTEXT_MESH_ENABLE_CODEX_HISTORY_MONITOR=1
# CONTEXT_MESH_ENABLE_OPENCODE_MONITOR=0
# CONTEXT_MESH_ENABLE_KILO_MONITOR=0
# CONTEXT_MESH_ENABLE_REMOTE_SYNC=0
# CONTEXT_MESH_ENABLE_CODEX_SESSION_MONITOR=1
# CONTEXT_MESH_ENABLE_CLAUDE_TRANSCRIPTS_MONITOR=1
# CONTEXT_MESH_ENABLE_ANTIGRAVITY_MONITOR=1
# CONTEXT_MESH_POLL_INTERVAL_SEC=180
# CONTEXT_MESH_FAST_POLL_INTERVAL_SEC=20
# CONTEXT_MESH_IDLE_SLEEP_CAP_SEC=600
# CONTEXT_MESH_HEARTBEAT_INTERVAL_SEC=600
# CONTEXT_MESH_IDLE_TIMEOUT_SEC=300
# CONTEXT_MESH_INDEX_SYNC_MIN_INTERVAL_SEC=20
# CONTEXT_MESH_LOOP_JITTER_SEC=0.7
# CONTEXT_MESH_ERROR_BACKOFF_MAX_SEC=30
# CONTEXT_MESH_CYCLE_BUDGET_SEC=8
# CONTEXT_MESH_NIGHT_POLL_INTERVAL_SEC=900
# CONTEXT_MESH_MAX_TRACKED_SESSIONS=240
# CONTEXT_MESH_MAX_FILE_CURSORS=800
# CONTEXT_MESH_SESSION_TTL_SEC=7200
# CONTEXT_MESH_MAX_MESSAGES_PER_SESSION=500
# CONTEXT_MESH_CODEX_SESSION_SCAN_INTERVAL_SEC=300
# CONTEXT_MESH_CLAUDE_TRANSCRIPT_SCAN_INTERVAL_SEC=300
# CONTEXT_MESH_ANTIGRAVITY_SCAN_INTERVAL_SEC=300
# CONTEXT_MESH_MAX_CODEX_SESSION_FILES_PER_SCAN=160
# CONTEXT_MESH_MAX_CLAUDE_TRANSCRIPT_FILES_PER_POLL=120
# CONTEXT_MESH_MAX_ANTIGRAVITY_DIRS_PER_SCAN=80
# CONTEXT_MESH_SUSPEND_ANTIGRAVITY_WHEN_BUSY=1
# CONTEXT_MESH_ANTIGRAVITY_BUSY_LS_THRESHOLD=2
# CONTEXT_MESH_ANTIGRAVITY_INGEST_MODE=final_only
# CONTEXT_MESH_ANTIGRAVITY_QUIET_SEC=240
# CONTEXT_MESH_ANTIGRAVITY_MIN_DOC_BYTES=500
# CONTEXT_MESH_EXPORT_HTTP_TIMEOUT_SEC=30
# CONTEXT_MESH_PENDING_HTTP_TIMEOUT_SEC=15


# --- Optional: Deploy ---
# CONTEXT_MESH_INSTALL_ROOT=$HOME/.local/share/context-mesh-foundry
# CMF_INSTALL_ROOT=$HOME/.local/share/context-mesh-foundry
# PATCH_LAUNCHD=1
# RELOAD_LAUNCHD=1

# --- Optional: Legacy compatibility shim ---
# ONECONTEXT_BIN=
# ONECONTEXT_DB_PATH=
# ALLOW_NOOP_MCP=0

# --- Optional: LiteLLM ---
# LITELLM_LOCAL_MODEL_COST_MAP=True
